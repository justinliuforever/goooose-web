    "import-archive": "tsx scripts/import-archive.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "tsx": "^4.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0"
  }
}
