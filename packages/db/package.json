{
  "name": "@singularity/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Drizzle ORM schema + migrations (single source of truth).",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
